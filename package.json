{
  "name": "blessed-ave",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "db:generate": "pnpm --filter @blessed-ave/db generate",
    "db:migrate": "pnpm --filter @blessed-ave/db migrate",
    "db:studio": "pnpm --filter @blessed-ave/db studio"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
