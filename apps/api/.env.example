# Database
DATABASE_URL="postgresql://user:password@localhost:5432/blessed_ave"

# JWT
JWT_SECRET="change-this-to-a-long-random-string"
JWT_REFRESH_SECRET="change-this-to-another-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email (for order confirmations — leave blank to disable)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="hello@blessedave.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Blessed Ave Cafe <hello@blessedave.com>"

# App
PORT=4000
NODE_ENV="development"
CLIENT_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"

# File uploads — Cloudflare R2 or AWS S3 (optional)
S3_BUCKET="blessed-ave-media"
S3_REGION="auto"
S3_ENDPOINT="https://xxxx.r2.cloudflarestorage.com"
S3_ACCESS_KEY="xxxx"
S3_SECRET_KEY="xxxx"
S3_PUBLIC_URL="https://media.blessedave.com"
